# Dependencies (massive, never need to scan)
node_modules/
**/node_modules/

# Build outputs
android/build/
android/app/build/
ios/build/
ios/DerivedData/
**/build/
**/dist/

# Git & version control
.git/
.gitignore
.gitattributes

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# OS metadata
.DS_Store
Thumbs.db
desktop.ini

# IDE / Editor folders
.vscode/
.idea/
*.swp
*.swo
*~

# Environment & secrets
.env
.env.*
!.env.example

# Temporary / cache files
.cache/
*.tmp
*.temp
.eslintcache
.prettiercache

# React Native / Metro
metro.config.js.local
**/fastlane/README.md
**/__tests__/**/*.js.map

# iOS pods (if using CocoaPods)
ios/Pods/

# Code coverage
coverage/
.nyc_output/

# Bundle / binary outputs (Android)
android/app/*.apk
android/app/*.aab

# Bundle / binary outputs (iOS)
*.ipa
*.dSYM.zip